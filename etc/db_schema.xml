<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="sales_order">
        <column xsi:type="varchar" length="255" name="order_from" nullable="true" comment="Where the order comes from"/>
        <column xsi:type="varchar" length="255" name="external_id" nullable="true" comment="External order ID"/>
        <column xsi:type="varchar" length="255" name="external_guid" nullable="true" comment="External order GUID"/>
        <column xsi:type="varchar" length="255" name="allegro_buyer_login" nullable="true" comment="Allegro buyer login"/>
        <constraint xsi:type="unique" referenceId="SALES_ORDER_ORDER_FROM_EXTERNAL_ID">
            <column name="order_from"/>
            <column name="external_id"/>
        </constraint>
    </table>

    <table name="sales_order_grid">
        <column xsi:type="varchar" length="255" name="order_from" nullable="true" comment="Where the order comes from"/>
        <column xsi:type="varchar" length="255" name="external_id" nullable="true" comment="External order ID"/>
        <column xsi:type="varchar" length="255" name="external_guid" nullable="true" comment="External order GUID"/>
        <column xsi:type="varchar" length="255" name="allegro_buyer_login" nullable="true" comment="Allegro buyer login"/>
    </table>

    <table name="quote">
        <column xsi:type="varchar" length="255" name="order_from" nullable="true" comment="Where the order comes from"/>
        <column xsi:type="varchar" length="255" name="external_id" nullable="true" comment="External order ID"/>
        <column xsi:type="varchar" length="255" name="external_guid" nullable="true" comment="External order GUID"/>
        <column xsi:type="varchar" length="255" name="allegro_buyer_login" nullable="true" comment="Allegro buyer login"/>
    </table>

    <table name="sales_order_item">
        <column xsi:type="varchar" length="255" name="allegro_line_item_id" nullable="true" comment="Allegro line item ID"/>
    </table>

    <table name="sales_order_pickup_point" resource="default">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="order_id" padding="10" unsigned="true" nullable="false" comment="Order ID"/>
        <column xsi:type="varchar" length="255" name="point_id" nullable="true" comment="Allegro pickup point ID"/>
        <column xsi:type="varchar" length="255" name="name" nullable="true" comment="Allegro pickup point name"/>
        <column xsi:type="varchar" length="255" name="description" nullable="true" comment="Allegro pickup point description"/>
        <column xsi:type="varchar" length="255" name="street" nullable="true" comment="Allegro pickup point address street"/>
        <column xsi:type="varchar" length="255" name="zip_code" nullable="true" comment="Allegro pickup point address zip code"/>
        <column xsi:type="varchar" length="255" name="city" nullable="true" comment="Allegro pickup point address city"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="SALES_ORDER_PICKUP_POINT_ORDER_ID">
            <column name="order_id"/>
        </constraint>
        <constraint
            xsi:type="foreign"
            referenceId="SALES_ORDER_PICKUP_POINT_ORDER_ID_SALES_ORDER_ENTITY_ID"
            table="sales_order_pickup_point"
            column="order_id"
            referenceTable="sales_order"
            referenceColumn="entity_id"
            onDelete="CASCADE"
        />
    </table>

    <table name="allegro_orders_with_errors" resource="default" engine="innodb" comment="Table with orders that could not be imported because of an error">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="checkout_form_id" nullable="false" comment="Checkout form ID"/>
        <column xsi:type="datetime" name="date_of_first_try" nullable="false" comment="Date of first import try"/>
        <column xsi:type="datetime" name="date_of_last_try" nullable="false" comment="Date of last import try"/>
        <column xsi:type="varchar" name="reason" nullable="false" comment="Error content"/>
        <column xsi:type="int" name="number_of_tries" nullable="false" comment="Number of tries to import"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="UNIQUE">
            <column name="checkout_form_id"/>
        </constraint>
    </table>

    <table name="allegro_order_import_state" resource="default" engine="innodb" comment="Idempotent Allegro checkout form import state">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="checkout_form_id" length="64" nullable="false" comment="Checkout Form ID"/>
        <column xsi:type="varchar" name="status" length="16" nullable="false" default="new" comment="Import Status"/>
        <column xsi:type="int" name="attempts" padding="10" unsigned="true" nullable="false" default="0" comment="Import Attempts"/>
        <column xsi:type="int" name="magento_order_id" padding="10" unsigned="true" nullable="true" comment="Magento Order ID"/>
        <column xsi:type="text" name="last_error" nullable="true" comment="Last Safe Error"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY"><column name="entity_id"/></constraint>
        <constraint xsi:type="unique" referenceId="ALLEGRO_ORDER_IMPORT_STATE_CHECKOUT_FORM_ID">
            <column name="checkout_form_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="ALLEGRO_ORDER_IMPORT_STATE_ORDER_ID_SALES_ORDER_ENTITY_ID" table="allegro_order_import_state" column="magento_order_id" referenceTable="sales_order" referenceColumn="entity_id" onDelete="SET NULL"/>
        <index referenceId="ALLEGRO_ORDER_IMPORT_STATE_STATUS_UPDATED_AT" indexType="btree">
            <column name="status"/><column name="updated_at"/>
        </index>
    </table>

    <table name="allegro_reservations" resource="default" engine="innodb" comment="Table with info about reservations for orders from Allegro that aren't paid yet">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="reservation_id" padding="10" unsigned="true" nullable="false" identity="false" comment="Reservation ID"/>
        <column xsi:type="varchar" name="checkout_form_id" nullable="false" comment="Checkout form ID"/>
        <column xsi:type="varchar" name="sku" nullable="false" comment="Product SKU"/>
        <column xsi:type="datetime" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Creation date"/>
        <constraint xsi:type="foreign" referenceId="FOREIGN" table="allegro_reservations" column="reservation_id" referenceTable="inventory_reservation" referenceColumn="reservation_id" onDelete="CASCADE"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="ALLEGRO_RESERVATIONS_CHECKOUT_FORM_SKU">
            <column name="checkout_form_id"/>
            <column name="sku"/>
        </constraint>
    </table>

    <table name="allegro_offer_mapping_reconciliation" resource="default" engine="innodb" comment="Allegro offer mappings awaiting reconciliation">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="product_id" padding="10" unsigned="true" nullable="false" comment="Magento Product ID"/>
        <column xsi:type="varchar" name="offer_id" length="64" nullable="false" comment="Allegro Offer ID"/>
        <column xsi:type="varchar" name="allegro_product_id" length="64" nullable="true" comment="Allegro Catalog Product ID"/>
        <column xsi:type="varchar" name="seller_id" length="64" nullable="true" comment="Allegro Seller ID"/>
        <column xsi:type="varchar" name="environment" length="16" nullable="false" comment="Allegro Environment"/>
        <column xsi:type="varchar" name="status" length="16" nullable="false" default="pending" comment="Reconciliation Status"/>
        <column xsi:type="int" name="attempts" padding="10" unsigned="true" nullable="false" default="0" comment="Reconciliation Attempts"/>
        <column xsi:type="text" name="last_error" nullable="true" comment="Last Safe Error Message"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="ALLEGRO_MAPPING_RECONCILIATION_PRODUCT_ID_CATALOG_PRODUCT_ENTITY_ENTITY_ID" table="allegro_offer_mapping_reconciliation" column="product_id" referenceTable="catalog_product_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="ALLEGRO_MAPPING_RECONCILIATION_OFFER_ENVIRONMENT">
            <column name="offer_id"/>
            <column name="environment"/>
        </constraint>
        <index referenceId="ALLEGRO_MAPPING_RECONCILIATION_STATUS_ATTEMPTS" indexType="btree">
            <column name="status"/>
            <column name="attempts"/>
        </index>
    </table>

    <table name="allegro_offer_mapping" resource="default" engine="innodb" comment="Environment-aware Allegro offer mapping">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="product_id" padding="10" unsigned="true" nullable="false" comment="Magento Product ID"/>
        <column xsi:type="varchar" name="offer_id" length="64" nullable="false" comment="Allegro Offer ID"/>
        <column xsi:type="varchar" name="allegro_product_id" length="64" nullable="true" comment="Allegro Catalog Product ID"/>
        <column xsi:type="varchar" name="seller_id" length="64" nullable="true" comment="Allegro Seller ID"/>
        <column xsi:type="varchar" name="environment" length="16" nullable="false" comment="Allegro Environment"/>
        <column xsi:type="timestamp" name="synced_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Last Mapping Synchronization"/>
        <constraint xsi:type="primary" referenceId="PRIMARY"><column name="entity_id"/></constraint>
        <constraint xsi:type="foreign" referenceId="ALLEGRO_OFFER_MAPPING_PRODUCT_ID_CATALOG_PRODUCT_ENTITY_ENTITY_ID" table="allegro_offer_mapping" column="product_id" referenceTable="catalog_product_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="ALLEGRO_OFFER_MAPPING_PRODUCT_ENVIRONMENT">
            <column name="product_id"/><column name="environment"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="ALLEGRO_OFFER_MAPPING_OFFER_ENVIRONMENT">
            <column name="offer_id"/><column name="environment"/>
        </constraint>
    </table>

    <table name="allegro_offer_sync_state" resource="default" engine="innodb" comment="Last successfully synchronized Allegro offer state">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="product_id" padding="10" unsigned="true" nullable="false" comment="Magento Product ID"/>
        <column xsi:type="varchar" name="offer_id" length="64" nullable="false" comment="Allegro Offer ID"/>
        <column xsi:type="varchar" name="environment" length="16" nullable="false" comment="Allegro Environment"/>
        <column xsi:type="varchar" name="state_hash" length="64" nullable="false" comment="Synchronized State Hash"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="ALLEGRO_OFFER_SYNC_STATE_PRODUCT_ID_CATALOG_PRODUCT_ENTITY_ENTITY_ID" table="allegro_offer_sync_state" column="product_id" referenceTable="catalog_product_entity" referenceColumn="entity_id" onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="ALLEGRO_OFFER_SYNC_STATE_PRODUCT_ENVIRONMENT">
            <column name="product_id"/>
            <column name="environment"/>
        </constraint>
        <index referenceId="ALLEGRO_OFFER_SYNC_STATE_OFFER_ID" indexType="btree">
            <column name="offer_id"/>
        </index>
    </table>

    <table name="allegro_outbound_sync_state" resource="default" engine="innodb" comment="Last successfully synchronized Allegro outbound operation">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="operation" length="32" nullable="false" comment="Operation Type"/>
        <column xsi:type="varchar" name="source_id" length="64" nullable="false" comment="Magento Source Entity ID"/>
        <column xsi:type="varchar" name="environment" length="16" nullable="false" comment="Allegro Environment"/>
        <column xsi:type="varchar" name="state_hash" length="64" nullable="false" comment="Synchronized State Hash"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="ALLEGRO_OUTBOUND_SYNC_OPERATION_SOURCE_ENVIRONMENT">
            <column name="operation"/>
            <column name="source_id"/>
            <column name="environment"/>
        </constraint>
    </table>

    <table name="allegro_async_failures" resource="default" engine="innodb" comment="Retry and dead registry for Allegro asynchronous operations">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="varchar" name="operation" length="32" nullable="false" comment="Operation Type"/>
        <column xsi:type="int" name="source_id" padding="10" unsigned="true" nullable="false" comment="Magento Source Entity ID"/>
        <column xsi:type="varchar" name="environment" length="16" nullable="false" comment="Allegro Environment"/>
        <column xsi:type="varchar" name="status" length="16" nullable="false" default="pending" comment="Retry Status"/>
        <column xsi:type="int" name="attempts" padding="10" unsigned="true" nullable="false" default="0" comment="Attempts"/>
        <column xsi:type="text" name="last_error" nullable="true" comment="Last Safe Error"/>
        <column xsi:type="timestamp" name="next_attempt_at" on_update="false" nullable="true" comment="Next Attempt At"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY"><column name="entity_id"/></constraint>
        <constraint xsi:type="unique" referenceId="ALLEGRO_ASYNC_FAILURE_OPERATION_SOURCE_ENVIRONMENT">
            <column name="operation"/><column name="source_id"/><column name="environment"/>
        </constraint>
        <index referenceId="ALLEGRO_ASYNC_FAILURE_STATUS_NEXT_ATTEMPT" indexType="btree">
            <column name="status"/><column name="next_attempt_at"/>
        </index>
    </table>

</schema>
