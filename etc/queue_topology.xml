<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework-message-queue:etc/topology.xsd">
    <exchange name="allegro.queue" type="topic" connection="amqp">
        <binding id="AllegroApiQueue" topic="allegro.change.stock" destinationType="queue" destination="allegro.api.queue"/>
        <binding id="AllegroOrderStatusQueue" topic="allegro.order.status" destinationType="queue" destination="allegro.order.status.queue"/>
        <binding id="AllegroShipmentQueue" topic="allegro.shipment" destinationType="queue" destination="allegro.shipment.queue"/>
    </exchange>
    <exchange name="allegro.api" type="topic" connection="db">
        <binding id="AllegroApiQueueDb" topic="allegro.change.stock.db" destinationType="queue" destination="allegro.api"/>
        <binding id="AllegroOrderStatusQueueDb" topic="allegro.order.status.db" destinationType="queue" destination="allegro.order.status.db"/>
        <binding id="AllegroShipmentQueueDb" topic="allegro.shipment.db" destinationType="queue" destination="allegro.shipment.db"/>
    </exchange>
</config>
