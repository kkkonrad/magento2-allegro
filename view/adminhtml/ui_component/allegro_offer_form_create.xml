<?xml version="1.0" encoding="UTF-8"?>
<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">allegro_offer_form_create.allegro_offer_form_create_data_source</item>
            <item name="deps" xsi:type="string">allegro_offer_form_create.allegro_offer_form_create_data_source</item>
        </item>
        <item name="label" xsi:type="string" translate="true">Allegro Offer Form</item>
        <item name="layout" xsi:type="array">
            <item name="type" xsi:type="string">tabs</item>
        </item>
        <item name="config" xsi:type="array">
            <item name="dataScope" xsi:type="string">data</item>
            <item name="namespace" xsi:type="string">allegro_offer_form_create</item>
        </item>
    </argument>

    <settings>
        <buttons>
            <button name="back" class="Macopedia\Allegro\Block\Adminhtml\Offer\BackButton"/>
            <button name="save" class="Macopedia\Allegro\Block\Adminhtml\Offer\SaveButton"/>
        </buttons>
        <namespace>allegro_offer_form_create</namespace>
        <dataScope>data</dataScope>
        <deps>
            <dep>allegro_offer_form_create.allegro_offer_form_create_data_source</dep>
        </deps>
    </settings>

    <dataSource name="allegro_offer_form_create_data_source">
        <argument name="data" xsi:type="array">
            <item name="js_config" xsi:type="array">
                <item name="component" xsi:type="string">Magento_Ui/js/form/provider</item>
            </item>
        </argument>
        <settings>
            <submitUrl path="allegro/offer/save"/>
        </settings>
        <dataProvider class="Macopedia\Allegro\Ui\AllegroOffer\Form\CreateDataProvider" name="allegro_offer_form_create_data_source">
            <settings>
                <requestFieldName>product</requestFieldName>
                <primaryFieldName>product</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>

    <fieldset name="allegro">
        <argument name="data" xsi:type="array">
            <item name="config" xsi:type="array">
                <item name="label" xsi:type="string" translate="true">Allegro Offer Form</item>
            </item>
        </argument>
        <field name="product">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                </item>
            </argument>
        </field>
        <field name="images">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                </item>
            </argument>
        </field>
        <field name="name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Name</item>
                    <item name="visible" xsi:type="boolean">true</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="component" xsi:type="string">Macopedia_Allegro/js/allegro_offer/form/field/name-length-counter</item>
                    <item name="elementTmpl" xsi:type="string">Macopedia_Allegro/allegro_offer/form/field/name-length-counter</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                        <item name="allegro-name-length" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="product_id">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="dataScope" xsi:type="string">product_id</item>
                </item>
            </argument>
        </field>
        <field name="ean">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">EAN</item>
                    <item name="visible" xsi:type="boolean">true</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="component" xsi:type="string">Macopedia_Allegro/js/allegro_offer/form/field/ean</item>
                    <item name="ajaxUrl" xsi:type="url" path="allegro/catalog/data"/>
                    <item name="elementTmpl" xsi:type="string">Macopedia_Allegro/allegro_offer/form/field/ean-with-button</item>
                </item>
            </argument>
        </field>
        <field name="allegro_product_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Allegro Product</item>
                    <item name="visible" xsi:type="boolean">true</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="disabled" xsi:type="boolean">true</item>
                    <item name="notice" xsi:type="string" translate="true">Product found in Allegro Catalog. The offer will be linked with it.</item>
                </item>
            </argument>
        </field>
        <field name="description">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">textarea</item>
                    <item name="label" xsi:type="string" translate="true">Description</item>
                    <item name="template" xsi:type="string">ui/form/field</item>
                    <item name="component" xsi:type="string">Macopedia_Allegro/js/allegro_offer/form/field/description</item>
                    <item name="wysiwyg" xsi:type="boolean">false</item>
                    <item name="rows" xsi:type="number">8</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="price">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Price</item>
                    <item name="visible" xsi:type="boolean">true</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="qty">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="label" xsi:type="string" translate="true">Quantity</item>
                    <item name="visible" xsi:type="boolean">true</item>
                    <item name="dataType" xsi:type="string">int</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                        <item name="validate-greater-than-zero" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="delivery_shipping_rates_id">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Macopedia\Allegro\Model\Config\Source\ShippingRates</item>
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="label" xsi:type="string" translate="true">Delivery price list</item>
                    <item name="template" xsi:type="string">ui/form/field</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="implied_warranty">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Macopedia\Allegro\Model\Config\Source\ImpliedWarranty</item>
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="label" xsi:type="string" translate="true">Implied warranty</item>
                    <item name="template" xsi:type="string">ui/form/field</item>
                </item>
            </argument>
        </field>
        <field name="return_policy">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Macopedia\Allegro\Model\Config\Source\ReturnPolicy</item>
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="label" xsi:type="string" translate="true">Return policy</item>
                    <item name="template" xsi:type="string">ui/form/field</item>
                </item>
            </argument>
        </field>
        <field name="warranty">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Macopedia\Allegro\Model\Config\Source\Warranty</item>
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="label" xsi:type="string" translate="true">Warranty</item>
                    <item name="template" xsi:type="string">ui/form/field</item>
                </item>
            </argument>
        </field>
        <field name="responsible_producer_id">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="label" xsi:type="string" translate="true">Responsible producer ID</item>
                    <item name="notice" xsi:type="string" translate="true">Use an ID from Allegro responsible producers. Leave empty only when Allegro Catalog already provides GPSR data.</item>
                </item>
            </argument>
        </field>
        <field name="responsible_producer_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="label" xsi:type="string" translate="true">Responsible producer name</item>
                    <item name="notice" xsi:type="string" translate="true">Alternative to the producer ID. The name must already exist in the Allegro producer dictionary.</item>
                </item>
            </argument>
        </field>
        <field name="responsible_person_id">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="label" xsi:type="string" translate="true">Responsible person ID</item>
                    <item name="notice" xsi:type="string" translate="true">Required when the producer is established outside the European Union.</item>
                </item>
            </argument>
        </field>
        <field name="responsible_person_name">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="label" xsi:type="string" translate="true">Responsible person name</item>
                    <item name="notice" xsi:type="string" translate="true">Alternative to the responsible person ID.</item>
                </item>
            </argument>
        </field>
        <field name="safety_information">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">textarea</item>
                    <item name="label" xsi:type="string" translate="true">Product safety information</item>
                    <item name="rows" xsi:type="number">5</item>
                    <item name="notice" xsi:type="string" translate="true">Plain text, 1–5000 characters. Leave empty only when the catalog product already contains safety information.</item>
                    <item name="validation" xsi:type="array">
                        <item name="max_text_length" xsi:type="number">5000</item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="tax_rate">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="label" xsi:type="string" translate="true">VAT rate</item>
                    <item name="default" xsi:type="string">23.00</item>
                    <item name="notice" xsi:type="string" translate="true">The rate must be supported by Allegro for the selected category and origin country.</item>
                    <item name="validation" xsi:type="array">
                        <item name="validate-number" xsi:type="boolean">true</item>
                        <item name="validate-zero-or-greater" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="tax_subject">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="visible" xsi:type="boolean">false</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="default" xsi:type="string">GOODS</item>
                </item>
            </argument>
        </field>
        <field name="delivery_handling_time">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Macopedia\Allegro\Model\Config\Source\HandlingTime</item>
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="label" xsi:type="string" translate="true">Handling time</item>
                    <item name="template" xsi:type="string">ui/form/field</item>
                    <item name="default" xsi:type="string">PT24H</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="payments_invoice">
            <argument name="data" xsi:type="array">
                <item name="options" xsi:type="object">Macopedia\Allegro\Model\Config\Source\PaymentsInvoice</item>
                <item name="config" xsi:type="array">
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="formElement" xsi:type="string">select</item>
                    <item name="label" xsi:type="string" translate="true">Invoice option</item>
                    <item name="template" xsi:type="string">ui/form/field</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="category">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Macopedia_Allegro/js/allegro_offer/form/field/category</item>
                    <item name="ajaxUrl" xsi:type="url" path="allegro/catalog/data"/>
                    <item name="elementTmpl" xsi:type="string">Macopedia_Allegro/allegro_offer/form/field/category</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Select category</item>
                    <item name="formElement" xsi:type="string">input</item>
                    <item name="validation" xsi:type="array">
                        <item name="required-entry" xsi:type="boolean">true</item>
                    </item>
                </item>
            </argument>
        </field>
        <field name="parameters">
            <argument name="data" xsi:type="array">
                <item name="config" xsi:type="array">
                    <item name="component" xsi:type="string">Macopedia_Allegro/js/allegro_offer/form/field/attributes-table</item>
                    <item name="ajaxUrl" xsi:type="url" path="allegro/catalog/data"/>
                    <item name="elementTmpl" xsi:type="string">Macopedia_Allegro/allegro_offer/form/field/attributes-table</item>
                    <item name="dataType" xsi:type="string">text</item>
                    <item name="label" xsi:type="string" translate="true">Attributes</item>
                    <item name="formElement" xsi:type="string">input</item>
                </item>
            </argument>
        </field>
    </fieldset>
</form>
